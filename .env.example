# ============================================
# Root Environment Variables
# Used by backend only (loaded via backend/.env)
# ============================================
# Copy this file to backend/.env and frontend/.env.local
# then fill in your actual values.

# ──── Backend (.env) ────

# Server
NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_your_service_key

# URLs
FRONTEND_URL=http://localhost:3001

# LINE Login (https://developers.line.biz/console/)
LINE_LOGIN_CHANNEL_ID=your_line_login_channel_id
LINE_LOGIN_CHANNEL_SECRET=your_line_login_channel_secret

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Lemon Squeezy (optional — fill when ready)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# ──── Frontend (.env.local) ────

# Backend API URL (used by Next.js rewrites)
NEXT_PUBLIC_API_URL=http://localhost:3000
